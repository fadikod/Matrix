# 1. Check if a number is positive, negative, or zero
num = float(input("Enter a number: "))

if num > 0:
    print("Positive number")
elif num < 0:
    print("Negative number")
else:
    print("Zero")


# 2. For loop to print numbers from 1 to 10
print("\nNumbers from 1 to 10:")
for i in range(1, 11):
    print(i)


# 3. While loop to print numbers from 10 down to 1
print("\nNumbers from 10 down to 1:")
i = 10
while i >= 1:
    print(i)
    i -= 1


# 4. Print all even numbers from 1 to 20
print("\nEven numbers from 1 to 20:")
for i in range(2, 21, 2):
    print(i)


# 5. Ask user for a number and check if it's big or small
user_num = int(input("\nEnter another number: "))

if user_num > 100:
    print("Big number!")
else:
    print("Small number!")
