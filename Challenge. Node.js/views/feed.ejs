<!DOCTYPE html>
<html>
<head>
    <title>Facebook Feed</title>
</head>

<body>

<h1>Welcome to Facebook</h1>

<h3>Add a Post</h3>

<form action="/feed/add" method="POST">

<input type="text" name="name" placeholder="Name" maxlength="15" required>

<br><br>

<textarea name="message" placeholder="Message" maxlength="40" required></textarea>

<br><br>

<button type="submit">Post</button>

</form>

<hr>

<h2>Posts</h2>

<% posts.forEach(post => { %>

<div>

<h3><%= post.name %></h3>

<p><%= post.message %></p>

<p><%= post.createdAt.toDateString() %></p>

<a href="/feed/<%= post._id %>">See More</a>

<hr>

</div>

<% }) %>

</body>
</html>